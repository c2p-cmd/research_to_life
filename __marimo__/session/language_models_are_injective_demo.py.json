          "data": {
            "text/html": "<div style='display: flex;flex: 1;flex-direction: column;justify-content: flex-start;align-items: normal;flex-wrap: nowrap;gap: 0.5rem'><span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"results\">Results</h2></span><span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><strong>Selected layer:</strong> <code>0</code></span></span><span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><strong>Original sequence</strong></span></span><span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><code>The weather today is pleasant and bright.</code></span></span><span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><strong>Reconstructed sequence</strong></span></span><span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><code>The weather today is pleasant and bright.</code></span></span><span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><strong>Mean cosine similarity to nearest embedding:</strong> <code>1.0000</code></span></span><span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\"><strong>Exact token recovery rate:</strong> <code>100.00%</code></span></span></div>"
          }
