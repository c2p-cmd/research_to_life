          }
        }
      ],
      "console": []
    },
    {
      "id": "lEQa",
      "code_hash": "4935962d3c002f003cc77cacae9c7178",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"model\">Model</h2>\n<span class=\"paragraph\">This demo uses <a href=\"https://huggingface.co/google/gemma-4-E2B-it\" rel=\"noopener noreferrer\" target=\"_blank\"><code>google/gemma-4-E2B-it</code></a> and compares hidden-state vectors against the model\u2019s input embedding table. The selected layer controls which internal representation is used for reconstruction.</span></span>"
          }
        }
      ],
